{
	admin off
}

:{$PORT}
root * /srv
file_server
encode zstd gzip
header {
	Strict-Transport-Security "max-age=31536000; includeSubDomains"
	X-Content-Type-Options "nosniff"
	X-Frame-Options "DENY"
	Referrer-Policy "strict-origin-when-cross-origin"
	Content-Security-Policy "default-src 'self'; script-src 'self' https://plausible.io; connect-src 'self' https://api.github.com https://plausible.io; img-src 'self'; style-src 'self' 'unsafe-inline'; base-uri 'self'; form-action 'self'"
}
